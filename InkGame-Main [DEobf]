local function CreateESP(player)
    if player == lp then return end
    local drawings = {
        Box = Drawing.new("Square"),
        Tracer = Drawing.new("Line"),
        Name = Drawing.new("Text"),
        Distance = Drawing.new("Text"),
        Highlight = Instance.new("Highlight"),
        RoleHighlight = Instance.new("Highlight")
    }

    drawings.Box.Thickness = 1
    drawings.Box.Filled = false
    drawings.Box.Transparency = 1
    drawings.Box.Visible = false

    drawings.Tracer.Thickness = 1
    drawings.Tracer.Visible = false

    drawings.Name.Size = 16
    drawings.Name.Center = true
    drawings.Name.Outline = true
    drawings.Name.Visible = false

    drawings.Distance.Size = 14
    drawings.Distance.Center = true
    drawings.Distance.Outline = true
    drawings.Distance.Visible = false

    drawings.Highlight.Enabled = false
    drawings.Highlight.FillColor = Settings.ESPColor
    drawings.Highlight.OutlineColor = Color3.new(1, 1, 1)
    drawings.Highlight.FillTransparency = Settings.FillTransparency
    drawings.Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

    drawings.RoleHighlight.Enabled = false
    drawings.RoleHighlight.OutlineColor = Color3.new(1, 1, 1)
    drawings.RoleHighlight.FillTransparency = Settings.FillTransparency
    drawings.RoleHighlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

    ESP_Objects[player] = drawings
end

for _, player in pairs(Players:GetPlayers()) do CreateESP(player) end
