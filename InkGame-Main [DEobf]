local function FindNewHiderTarget()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 and IsHider(p) then
                return p
            end
        end
    end
    return nil
end

local function StartStalkingHider()
    if Settings.StalkConnection then
        Settings.StalkConnection:Disconnect()
        Settings.StalkConnection = nil
    end
    if not Settings.StalkHider then return end

    local targetHider = FindNewHiderTarget()
    if not targetHider then return end
    Settings.CurrentTargetHider = targetHider

    local char = lp.Character
    if char then
        local knife = char:FindFirstChild("Couteau") or char:FindFirstChild("Knife")
        if not knife then
