local autoCycleActive = false
local FLY_TIME = 5
local PAUSE_TIME = 0.1

local function startAutoCycle()
    if autoCycleActive then return end
    autoCycleActive = true
    
    task.spawn(function()
        while autoCycleActive do
            startFly()
            task.wait(FLY_TIME)
            if not autoCycleActive then break end
            stopFly()
            task.wait(PAUSE_TIME)
        end
    end)
end

local function stopAutoCycle()
    autoCycleActive = false
    stopFly()
end

local function initFlyCycle()
    stopAutoCycle()
    task.wait(0.1)
    startAutoCycle()
end

