local dashEnabled = false
local lastDashTime = 0
local dashBtnGui = nil
local currentDashAnimTrack = nil

local function PlayDashAnim(direction, hum)
    local animFolder = ReplicatedStorage:FindFirstChild("Animations") and ReplicatedStorage.Animations:FindFirstChild("Dashing")
    if not animFolder then return end
    
    local animIds = {
        Forward = animFolder:FindFirstChild("Forward"),
        Backwards = animFolder:FindFirstChild("Backwards"),
        Left = animFolder:FindFirstChild("Left"),
        Right = animFolder:FindFirstChild("Right"),
    }
    
    local anim = animIds[direction]
    if not anim or not hum then return end
    if currentDashAnimTrack then currentDashAnimTrack:Stop(0.1) end
    currentDashAnimTrack = hum:LoadAnimation(anim)
    currentDashAnimTrack.Priority = Enum.AnimationPriority.Action
    currentDashAnimTrack:Play(0.1)
end

local function DoDash()
    if not dashEnabled or (tick() - lastDashTime < 3) then return end
    
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum or hum.Health <= 0 then return end

    lastDashTime = tick()

    local moveDir = hum.MoveDirection
    local directionVector = hrp.CFrame.LookVector
    local powerMultiplier = 1
    local dashAnim = "Forward"

    if moveDir.Magnitude > 0.1 then
        directionVector = moveDir
        local dotForward = moveDir:Dot(hrp.CFrame.LookVector)
        local dotRight = moveDir:Dot(hrp.CFrame.RightVector)

        if dotForward > 0.6 then 
            dashAnim = "Forward"
            powerMultiplier = 1
        elseif dotForward < -0.6 then 
            dashAnim = "Backwards"
            powerMultiplier = 1 / 1.7
        elseif math.abs(dotRight) > 0.6 then 
            dashAnim = (dotRight > 0) and "Right" or "Left"
            powerMultiplier = 1 / 1.5
        end
    end

    PlayDashAnim(dashAnim, hum)

    local attachment = Instance.new("Attachment", hrp)
    local lv = Instance.new("LinearVelocity", hrp)
    lv.Attachment0 = attachment
    lv.MaxForce = 999999
    lv.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
    
    local duration = 0.5
    local baseStart = 45 
    local basePeak = 68  
    local baseEnd = 15   

    task.spawn(function()
        local elapsed = 0
        while elapsed < duration do
            local dt = RunService.Heartbeat:Wait()
            elapsed = elapsed + dt
            local t = elapsed / duration

            local currentSpeed
            local sSpeed = baseStart * powerMultiplier
            local pSpeed = basePeak * powerMultiplier
            local eSpeed = baseEnd * powerMultiplier

            if t < 0.3 then
                currentSpeed = sSpeed + (pSpeed - sSpeed) * (t / 0.3)
            elseif t < 0.7 then
                currentSpeed = pSpeed
            else
                currentSpeed = pSpeed - (pSpeed - eSpeed) * ((t - 0.7) / 0.3)
            end

            lv.VectorVelocity = directionVector * currentSpeed
        end
        
        lv:Destroy()
        attachment:Destroy()
        if currentDashAnimTrack then currentDashAnimTrack:Stop(0.2) end
    end)
end

local function CreateDashButton()
    if dashBtnGui then dashBtnGui:Destroy() end
    
    local gui = Instance.new("ScreenGui")
    gui.Name = "BalancedDashGUI"
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.Parent = lp:WaitForChild("PlayerGui")
    
    local btn = Instance.new("TextButton")
    btn.Name = "DashBtn"
    btn.Size = UDim2.fromOffset(90, 90)
    local centerX = (gui.AbsoluteSize.X / 2) - 45
    local centerY = (gui.AbsoluteSize.Y / 2) - 45
    btn.Position = UDim2.new(0, centerX, 0, centerY)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    btn.Text = "⚡ DASH"
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 15
    btn.Font = Enum.Font.GothamBold
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.Parent = gui
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0.35, 0)
    corner.Parent = btn
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(100, 200, 255)
    stroke.Thickness = 2.5
    stroke.Transparency = 0.2
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = btn
    
    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 140, 255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(20, 80, 200)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(10, 30, 120)),
    })
    grad.Rotation = 135
    grad.Parent = btn
    
    local dragData = { active = false, startPos = nil, startMouse = nil }
    
    local function onInputBegan(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragData.active = true
            dragData.startPos = btn.Position
            dragData.startMouse = input.Position
        end
    end
    
    local function onInputChanged(input)
        if not dragData.active then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragData.startMouse
            local newX = dragData.startPos.X.Offset + delta.X
            local newY = dragData.startPos.Y.Offset + delta.Y
            btn.Position = UDim2.new(0, newX, 0, newY)
        end
    end
    
    local function onInputEnded(input)
        if not dragData.active then return end
        dragData.active = false
        if dragData.startMouse and input and input.Position then
            local delta = (input.Position - dragData.startMouse).Magnitude
            if delta < 5 then
                DoDash()
            end
        end
    end
    
    btn.InputBegan:Connect(onInputBegan)
    btn.InputChanged:Connect(onInputChanged)
    btn.InputEnded:Connect(onInputEnded)
    
    local function onPress()
        grad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 220, 80)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 100, 40)),
        })
    end
    
    local function onRelease()
        grad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 140, 255)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(20, 80, 200)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(10, 30, 120)),
        })
    end
    
    btn.MouseButton1Down:Connect(onPress)
    btn.MouseButton1Up:Connect(onRelease)
    
    btn.TouchTap:Connect(function()
        onPress()
        task.wait(0.1)
        onRelease()
    end)
    
    task.spawn(function()
        while btn and btn.Parent do
            local rem = 3 - (tick() - lastDashTime)
            if rem > 0 then
                btn.Text = "⏳ " .. math.ceil(rem) .. "s"
                btn.BackgroundTransparency = 0.5
                stroke.Color = Color3.fromRGB(100, 100, 100)
            else
                btn.Text = "⚡ DASH"
                btn.BackgroundTransparency = 0
                stroke.Color = Color3.fromRGB(100, 200, 255)
            end
            task.wait(0.1)
        end
    end)
    
    dashBtnGui = gui
end

